# Archivo de ejemplo para la instancia aislada de Kong.
# Copiar a .env y reemplazar URLs y secretos reales.

TZ=America/Guayaquil

KONG_PG_DATABASE=kong
KONG_PG_USER=kong
KONG_PG_PASSWORD=change_me_kong_password
KONG_LOG_LEVEL=notice

KONGA_PG_DATABASE=konga
KONGA_PG_USER=konga
KONGA_PG_PASSWORD=change_me_konga_password

# Backends Core
CORE_BCK_SEC_URL=http://IP_PUBLICA_CORE:8012
CORE_BCK_CLI_URL=http://IP_PUBLICA_CORE:8010
CORE_BCK_ADM_URL=http://IP_PUBLICA_CORE:8008
CORE_BCK_CON_URL=http://IP_PUBLICA_CORE:8007
CORE_BCK_TRA_URL=http://IP_PUBLICA_CORE:8009
CORE_BCK_DOC_URL=http://IP_PUBLICA_CORE:8013
CORE_BCK_NOT_URL=http://IP_PUBLICA_CORE:8011

# Backends Switch
SW_BCK_ENR_URL=http://IP_PUBLICA_SWITCH:8014
SW_BCK_FAC_URL=http://IP_PUBLICA_SWITCH:8015
SW_BCK_LOT_URL=http://IP_PUBLICA_SWITCH:8016
SW_BCK_PIN_URL=http://IP_PUBLICA_SWITCH:8017
SW_BCK_REP_URL=http://IP_PUBLICA_SWITCH:8018

# Frontends
CORE_FR_WEB_URL=http://IP_PUBLICA_FRONT:3000
CORE_FR_VEN_URL=http://IP_PUBLICA_FRONT:3001
SW_FR_APP_URL=http://IP_PUBLICA_FRONT:3002
