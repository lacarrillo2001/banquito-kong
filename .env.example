# ============================================================
# Banco BanQuito V2 - Infra / Apps / Kong
# Copiar a .env y reemplazar secretos antes de desplegar.
# No subir .env a GitHub.
# ============================================================

TZ=America/Guayaquil
APP_VERSION=local

# MySQL shared lab credentials. Cambiar en nube/produccion.
MYSQL_ROOT_PASSWORD=change_me_root_password
MYSQL_USER=banquito_app
MYSQL_PASSWORD=change_me_app_password

# MongoDB document service
MONGO_INITDB_ROOT_USERNAME=banquito_mongo
MONGO_INITDB_ROOT_PASSWORD=change_me_mongo_password

# RabbitMQ opcional - no se levanta por defecto en Core
RABBITMQ_DEFAULT_USER=banquito_rabbit
RABBITMQ_DEFAULT_PASS=change_me_rabbit_password
BANQUITO_EVENTS_EXCHANGE=banquito.events.exchange

# JWT compartido por todos los microservicios
JWT_ISSUER=banquito-identity-access
JWT_SECRET=change_me_strong_shared_jwt_secret_at_least_32_chars
ACCESS_TOKEN_MINUTES=15
REFRESH_TOKEN_DAYS=7

# Flyway / JPA
FLYWAY_ENABLED=true
FLYWAY_BASELINE_ON_MIGRATE=true
FLYWAY_BASELINE_VERSION=1

# Demo data
IDENTITY_DEMO_DATA_ENABLED=true
IDENTITY_DEMO_PASSWORD=password
CUSTOMER_DEMO_DATA_ENABLED=false
ADMIN_DEMO_DATA_ENABLED=true
DOCUMENT_DEMO_ENABLED=true

# Account / Accounting
ACCOUNTING_DEFAULT_CUTOFF_TIME=20:00:00
ACCOUNTING_DATE_SOURCE=local
RECENT_TRANSACTIONS_LIMIT=20
DB_MAX_POOL_SIZE=10
DB_MIN_IDLE=2
DB_CONNECTION_TIMEOUT_MS=30000

# Notification / SMTP
# SIMULATED: no envia correo real.
# SMTP: envia a SMTP_HOST/SMTP_PORT. Para laboratorio usar Mailpit.
NOTIFICATION_DELIVERY_MODE=SMTP
NOTIFICATION_PROVIDER=SMTP
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_AUTH=false
SMTP_STARTTLS_ENABLE=false
SMTP_FROM=no-reply@banquito.com
SMTP_REPLY_TO=
MAILPIT_MAX_MESSAGES=5000

# Document service
DOCUMENT_RABBITMQ_ENABLED=false
DOCUMENT_STORAGE_MODE=MONGODB_PAYLOAD

# Kong
KONG_PG_DATABASE=kong
KONG_PG_USER=kong
KONG_PG_PASSWORD=change_me_kong_password
KONG_LOG_LEVEL=notice
